# ---- Django ----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# Comma-separated hostnames/IPs that may serve the app
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins for CSRF (include scheme), e.g. https://kartuli.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ---- Database ----
# Used by docker-compose / Coolify. For local dev you can leave DATABASE_URL unset to use SQLite.
DATABASE_URL=postgres://kartuli:kartuli@db:5432/kartuli
POSTGRES_USER=kartuli
POSTGRES_PASSWORD=kartuli
POSTGRES_DB=kartuli

# ---- OpenRouter (chat + PDF parsing models) ----
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: shown to OpenRouter for rankings
OPENROUTER_APP_NAME=Kartuli Tutor
OPENROUTER_SITE_URL=http://localhost:8000

# ---- OpenAI (embeddings only) ----
# Used for semantic search over lessons + Mem0 memory. Cheap.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Mem0 (self-hosted, uses Postgres + pgvector) ----
# Set to False to disable the memory layer (app still works).
MEM0_ENABLED=True
